<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>JASSO GPA Calculator — 奨学金 GPA 換算</title>
<meta name="description" content="Unofficial GPA calculator using JASSO's grade-point conversion formula, for Thai students checking eligibility for JASSO-linked scholarships and exchange programs." />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@500;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
  :root{
    --paper:#FAF9F5;
    --paper-line:#E4E1D8;
    --ink:#1B1B18;
    --ink-soft:#6B6A62;
    --hanko:#B3261E;
    --hanko-soft:#B3261E22;
    --pass:#2F6F4E;
    --pass-soft:#2F6F4E14;
    --fail:#B3261E;
    --fail-soft:#B3261E14;
    --field-bg:#FFFFFF;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:var(--paper);
    color:var(--ink);
    font-family:'Inter',system-ui,sans-serif;
    line-height:1.5;
    background-image:
      linear-gradient(var(--paper-line) 1px, transparent 1px);
    background-size: 100% 44px;
    background-attachment:local;
  }
  .wrap{max-width:840px;margin:0 auto;padding:56px 24px 100px;}

  /* Header */
  header{position:relative;padding-bottom:28px;margin-bottom:36px;border-bottom:2px solid var(--ink);}
  .eyebrow{
    font-family:'JetBrains Mono',monospace;
    font-size:12px;letter-spacing:.12em;text-transform:uppercase;
    color:var(--ink-soft);margin-bottom:10px;
  }
  h1{
    font-family:'Noto Serif JP',serif;
    font-weight:700;
    font-size:clamp(28px,5vw,42px);
    margin:0 0 8px;
    letter-spacing:-0.01em;
  }
  h1 .jp{font-size:0.55em;color:var(--ink-soft);font-weight:500;margin-left:10px;}
  .lede{color:var(--ink-soft);font-size:15px;max-width:56ch;margin:0;}
  .stamp{
    position:absolute; top:0; right:0;
    width:76px;height:76px;border-radius:50%;
    border:3px solid var(--hanko);
    display:flex;align-items:center;justify-content:center;
    transform:rotate(-9deg);
    font-family:'Noto Serif JP',serif;
    color:var(--hanko);font-weight:700;font-size:13px;
    text-align:center;line-height:1.15;
    opacity:.85;
  }

  section{margin-bottom:40px;}
  .section-label{
    font-family:'JetBrains Mono',monospace;
    font-size:12px;letter-spacing:.08em;text-transform:uppercase;
    color:var(--ink-soft);
    display:flex;align-items:center;gap:10px;margin-bottom:16px;
  }
  .section-label::after{content:"";flex:1;height:1px;background:var(--paper-line);}

  /* Bulk paste */
  .paste-row{display:flex;gap:10px;flex-wrap:wrap;align-items:flex-start;}
  textarea{
    flex:1;min-width:240px;
    font-family:'JetBrains Mono',monospace;font-size:14px;
    padding:12px 14px;border:1px solid var(--paper-line);border-radius:4px;
    background:var(--field-bg);resize:vertical;min-height:44px;
    color:var(--ink);
  }
  textarea:focus, select:focus, input:focus{outline:2px solid var(--ink); outline-offset:1px;}
  .btn{
    font-family:'Inter',sans-serif;font-weight:600;font-size:14px;
    padding:11px 18px;border-radius:4px;border:1px solid var(--ink);
    background:var(--ink);color:var(--paper);cursor:pointer;
    white-space:nowrap;
  }
  .btn:hover{background:#000;}
  .btn.ghost{background:transparent;color:var(--ink);}
  .btn.ghost:hover{background:var(--ink);color:var(--paper);}
  .hint{font-size:12.5px;color:var(--ink-soft);margin-top:8px;}

  /* Credit field */
  .credit-row{display:flex;align-items:center;gap:12px;flex-wrap:wrap;}
  .credit-row label{font-size:14px;color:var(--ink-soft);}
  .credit-row input[type=number]{
    width:64px;text-align:center;
    font-family:'JetBrains Mono',monospace;font-size:15px;font-weight:600;
    padding:8px;border:1px solid var(--paper-line);border-radius:4px;background:var(--field-bg);
  }
  .meta{font-size:13px;color:var(--ink-soft);margin-left:auto;font-family:'JetBrains Mono',monospace;}

  /* Grade grid */
  .grade-grid{
    display:grid;grid-template-columns:repeat(auto-fill,minmax(76px,1fr));
    gap:8px;
  }
  .grade-cell{display:flex;flex-direction:column;align-items:center;gap:4px;}
  .grade-cell select{
    width:100%;padding:9px 4px;text-align:center;
    font-family:'JetBrains Mono',monospace;font-weight:600;font-size:14px;
    border:1px solid var(--paper-line);border-radius:4px;background:var(--field-bg);
    color:var(--ink);appearance:none;
  }
  .grade-cell .idx{font-size:10px;color:var(--ink-soft);font-family:'JetBrains Mono',monospace;}
  .grade-cell .rm{
    border:none;background:none;color:var(--ink-soft);font-size:11px;cursor:pointer;
    text-decoration:underline;padding:2px;
  }
  .grade-cell .rm:hover{color:var(--fail);}
  .empty-state{
    padding:32px 16px;text-align:center;color:var(--ink-soft);
    border:1px dashed var(--paper-line);border-radius:6px;font-size:14px;
  }

  /* Ledger table */
  table.ledger{width:100%;border-collapse:collapse;font-size:14px;}
  table.ledger th{
    text-align:left;font-family:'JetBrains Mono',monospace;font-size:11px;
    letter-spacing:.05em;text-transform:uppercase;color:var(--ink-soft);
    font-weight:600;padding:0 0 10px;border-bottom:1px solid var(--ink);
  }
  table.ledger th:last-child, table.ledger td:last-child{text-align:right;}
  table.ledger td{padding:10px 0;border-bottom:1px solid var(--paper-line);}
  table.ledger td.gp{font-family:'JetBrains Mono',monospace;font-weight:700;}
  table.ledger tr.total td{border-bottom:none;border-top:2px solid var(--ink);padding-top:12px;font-weight:700;}

  /* Result */
  .result{
    border:1px solid var(--paper-line); border-radius:8px;
    padding:32px; text-align:center; position:relative; overflow:hidden;
    background:var(--field-bg);
    transition:background .2s, border-color .2s;
  }
  .result.pass{background:var(--pass-soft); border-color:var(--pass);}
  .result.fail{background:var(--fail-soft); border-color:var(--fail);}
  .result .label{font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-soft);}
  .result .gpa{font-family:'Noto Serif JP',serif;font-weight:700;font-size:64px;margin:6px 0 4px;line-height:1;}
  .result.pass .gpa{color:var(--pass);}
  .result.fail .gpa{color:var(--fail);}
  .result .raw{font-family:'JetBrains Mono',monospace;font-size:12.5px;color:var(--ink-soft);}
  .result .verdict{margin-top:16px;font-size:15px;font-weight:600;}
  .result.pass .verdict{color:var(--pass);}
  .result.fail .verdict{color:var(--fail);}
  .result .hanko-mark{
    position:absolute; top:18px; right:22px;
    font-family:'Noto Serif JP',serif; font-weight:700; font-size:15px;
    border:2.5px solid; border-radius:50%; width:58px;height:58px;
    display:flex;align-items:center;justify-content:center; transform:rotate(8deg);
    opacity:.9;
  }
  .result.pass .hanko-mark{border-color:var(--pass); color:var(--pass);}
  .result.fail .hanko-mark{border-color:var(--fail); color:var(--fail);}

  footer{margin-top:52px; padding-top:20px; border-top:1px solid var(--paper-line); font-size:12.5px; color:var(--ink-soft);}
  footer a{color:var(--ink);}
  code{font-family:'JetBrains Mono',monospace; background:var(--paper-line); padding:1px 5px; border-radius:3px; font-size:.92em;}

  @media (prefers-reduced-motion: reduce){ *{transition:none !important;} }
</style>
</head>
<body>
<div class="wrap">

  <header>
    <div class="stamp">JASSO<br>GPA</div>
    <div class="eyebrow">Unofficial calculator</div>
    <h1>JASSO GPA Calculator<span class="jp">奨学金 GPA 計算</span></h1>
    <p class="lede">
      คำนวณ GPA ตามสูตรของ JASSO (5-level scale: A / B / C / D / F) สำหรับตรวจสอบคุณสมบัติ
      ทุนแลกเปลี่ยน/ฝึกงานที่ญี่ปุ่นที่อ้างอิงเกณฑ์ขั้นต่ำ GPA 2.30 — ไม่ใช่เครื่องมือทางการของ JASSO
    </p>
  </header>

  <section>
    <div class="section-label">วางเกรดแบบรวดเร็ว</div>
    <div class="paste-row">
      <textarea id="bulkInput" rows="2" placeholder="วางเกรดคั่นด้วยช่องว่าง เช่น: A B+ C- D A- A B C+ F"></textarea>
      <button class="btn" id="loadBtn">โหลดเกรด</button>
      <button class="btn ghost" id="clearBtn">ล้างทั้งหมด</button>
    </div>
    <p class="hint">รองรับเกรด: A, A-, B+, B, B-, C+, C, C-, D+, D, F — พิมพ์คั่นด้วยช่องว่างหรือคอมมาก็ได้</p>
  </section>

  <section>
    <div class="section-label">หน่วยกิต</div>
    <div class="credit-row">
      <label for="creditInput">หน่วยกิตต่อวิชา:</label>
      <input type="number" id="creditInput" value="3" min="0" step="0.5" />
      <span class="meta" id="metaInfo">0 วิชา · 0 หน่วยกิต</span>
    </div>
  </section>

  <section>
    <div class="section-label">รายวิชา</div>
    <div id="gradeGrid" class="grade-grid"></div>
    <div id="emptyState" class="empty-state">ยังไม่มีเกรด — วางเกรดด้านบน หรือกด "เพิ่มวิชา"</div>
    <div style="margin-top:14px;">
      <button class="btn ghost" id="addBtn">+ เพิ่มวิชา</button>
    </div>
  </section>

  <section>
    <div class="section-label">สรุปตาม Grade Point</div>
    <table class="ledger">
      <thead>
        <tr><th>GP</th><th>เกรดที่รวม</th><th>วิชา</th><th>หน่วยกิต</th></tr>
      </thead>
      <tbody id="ledgerBody"></tbody>
    </table>
  </section>

  <section>
    <div class="section-label">ผลลัพธ์</div>
    <div class="result" id="resultCard">
      <div class="hanko-mark" id="hankoMark">—</div>
      <div class="label">JASSO GPA</div>
      <div class="gpa" id="gpaDisplay">0.00</div>
      <div class="raw" id="gpaRaw">ค่าจริงก่อนปัด: 0.0000</div>
      <div class="verdict" id="verdictText">กรอกเกรดเพื่อเริ่มคำนวณ</div>
    </div>
  </section>

  <footer>
    เกณฑ์ขั้นต่ำ 2.30 เป็นเกณฑ์ทั่วไปของ JASSO — บางโครงการ/มหาวิทยาลัยอาจกำหนดเกณฑ์สูงกว่านี้ กรุณาตรวจสอบประกาศทุนของโครงการนั้น ๆ อีกครั้ง
    เครื่องมือนี้ไม่ใช่เครื่องมือทางการของ JASSO ใช้เพื่อประมาณผลเบื้องต้นเท่านั้น ·
    วิธีคำนวณอ้างอิงจาก <code>([No.GP3]×3 + [No.GP2]×2 + [No.GP1]×1 + [No.GP0]×0) / รวมหน่วยกิต</code>
  </footer>

</div>

<script>
const GRADE_POINTS = {
  "A":3, "A-":3, "B+":3, "B":3, "B-":3,
  "C+":2, "C":2, "C-":2,
  "D+":1, "D":1,
  "F":0
};
const GRADE_LIST = Object.keys(GRADE_POINTS);

let grades = [];

const gradeGrid   = document.getElementById('gradeGrid');
const emptyState  = document.getElementById('emptyState');
const ledgerBody  = document.getElementById('ledgerBody');
const metaInfo    = document.getElementById('metaInfo');
const gpaDisplay  = document.getElementById('gpaDisplay');
const gpaRaw      = document.getElementById('gpaRaw');
const verdictText = document.getElementById('verdictText');
const resultCard  = document.getElementById('resultCard');
const hankoMark   = document.getElementById('hankoMark');
const creditInput = document.getElementById('creditInput');

function optionsHtml(selected){
  return GRADE_LIST.map(g => `<option value="${g}" ${g===selected?'selected':''}>${g}</option>`).join('');
}

function renderGrid(){
  gradeGrid.innerHTML = '';
  emptyState.style.display = grades.length === 0 ? 'block' : 'none';
  grades.forEach((g, i) => {
    const cell = document.createElement('div');
    cell.className = 'grade-cell';
    cell.innerHTML = `
      <span class="idx">${i+1}</span>
      <select data-idx="${i}">${optionsHtml(g)}</select>
      <button class="rm" data-idx="${i}">ลบ</button>
    `;
    gradeGrid.appendChild(cell);
  });

  gradeGrid.querySelectorAll('select').forEach(sel => {
    sel.addEventListener('change', e => {
      grades[+e.target.dataset.idx] = e.target.value;
      compute();
    });
  });
  gradeGrid.querySelectorAll('.rm').forEach(btn => {
    btn.addEventListener('click', e => {
      grades.splice(+e.target.dataset.idx, 1);
      renderGrid();
      compute();
    });
  });
}

function parseGradeToken(tok){
  const t = tok.trim().toUpperCase();
  if (GRADE_LIST.includes(t)) return t;
  // normalize common variants
  const map = { "A+":"A" };
  if (map[t]) return map[t];
  return null;
}

document.getElementById('loadBtn').addEventListener('click', () => {
  const raw = document.getElementById('bulkInput').value;
  const tokens = raw.split(/[\s,]+/).filter(Boolean);
  const parsed = [];
  const rejected = [];
  tokens.forEach(t => {
    const g = parseGradeToken(t);
    if (g) parsed.push(g); else rejected.push(t);
  });
  grades = grades.concat(parsed);
  renderGrid();
  compute();
  if (rejected.length){
    alert('ไม่รู้จักเกรดต่อไปนี้ (ข้ามไปแล้ว): ' + rejected.join(', '));
  }
  document.getElementById('bulkInput').value = '';
});

document.getElementById('clearBtn').addEventListener('click', () => {
  if (grades.length && !confirm('ล้างเกรดทั้งหมด?')) return;
  grades = [];
  renderGrid();
  compute();
});

document.getElementById('addBtn').addEventListener('click', () => {
  grades.push('A');
  renderGrid();
  compute();
});

creditInput.addEventListener('input', compute);

function roundTwo(n){
  // half-up rounding to 2 decimals, matching JASSO's stated rule
  return Math.round((n + Number.EPSILON) * 100) / 100;
}

function compute(){
  const creditPerCourse = parseFloat(creditInput.value) || 0;
  const buckets = {3:0, 2:0, 1:0, 0:0};
  grades.forEach(g => { buckets[GRADE_POINTS[g]] += 1; });

  const totalCourses = grades.length;
  const totalCredits = totalCourses * creditPerCourse;
  const numerator = buckets[3]*creditPerCourse*3 + buckets[2]*creditPerCourse*2 + buckets[1]*creditPerCourse*1 + buckets[0]*creditPerCourse*0;
  const gpaRawVal = totalCredits > 0 ? numerator / totalCredits : 0;
  const gpaRounded = roundTwo(gpaRawVal);
  const pass = totalCourses > 0 && gpaRounded >= 2.30;

  metaInfo.textContent = `${totalCourses} วิชา · ${totalCredits} หน่วยกิต`;

  ledgerBody.innerHTML = `
    <tr><td class="gp">3</td><td>A, A-, B+, B, B-</td><td>${buckets[3]}</td><td>${buckets[3]*creditPerCourse}</td></tr>
    <tr><td class="gp">2</td><td>C+, C, C-</td><td>${buckets[2]}</td><td>${buckets[2]*creditPerCourse}</td></tr>
    <tr><td class="gp">1</td><td>D+, D</td><td>${buckets[1]}</td><td>${buckets[1]*creditPerCourse}</td></tr>
    <tr><td class="gp">0</td><td>F</td><td>${buckets[0]}</td><td>${buckets[0]*creditPerCourse}</td></tr>
    <tr class="total"><td colspan="2">รวม</td><td>${totalCourses}</td><td>${totalCredits}</td></tr>
  `;

  gpaDisplay.textContent = gpaRounded.toFixed(2);
  gpaRaw.textContent = `ค่าจริงก่อนปัด: ${gpaRawVal.toFixed(4)}`;

  resultCard.classList.remove('pass','fail');
  if (totalCourses === 0){
    verdictText.textContent = 'กรอกเกรดเพื่อเริ่มคำนวณ';
    hankoMark.textContent = '—';
    hankoMark.style.borderColor = 'var(--paper-line)';
    hankoMark.style.color = 'var(--ink-soft)';
  } else if (pass){
    resultCard.classList.add('pass');
    verdictText.textContent = `✅ ผ่านเกณฑ์ขั้นต่ำ 2.30 (ห่างกัน +${(gpaRounded-2.30).toFixed(2)})`;
    hankoMark.textContent = '合格';
  } else {
    resultCard.classList.add('fail');
    verdictText.textContent = `❌ ไม่ผ่านเกณฑ์ขั้นต่ำ 2.30 (ขาดอีก ${(2.30-gpaRounded).toFixed(2)})`;
    hankoMark.textContent = '不可';
  }
}

renderGrid();
compute();
</script>
</body>
</html>